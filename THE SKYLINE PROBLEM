import java.util.*;

class Solution {
    public List<List<Integer>> getSkyline(int[][] buildings) {
        List<int[]> events = new ArrayList<>();
        for (int[] b : buildings) {
            // Start event: height is negative to differentiate and sort correctly
            events.add(new int[]{b[0], -b[2]});
            // End event: height is positive
            events.add(new int[]{b[1], b[2]});
        }

        // Sort events:
        // 1. By x-coordinate.
        // 2. If x is same, sort by height (handling overlaps).
        Collections.sort(events, (a, b) -> {
            if (a[0] != b[0]) return a[0] - b[0];
            return a[1] - b[1];
        });

        List<List<Integer>> result = new ArrayList<>();
        // Max-Heap to store current active heights
        PriorityQueue<Integer> maxHeap = new PriorityQueue<>(Collections.reverseOrder());
        maxHeap.offer(0); // Ground level
        int prevMaxHeight = 0;

        for (int[] event : events) {
            int x = event[0];
            int h = event[1];

            if (h < 0) {
                // Building starts
                maxHeap.offer(-h);
            } else {
                // Building ends
                maxHeap.remove(h);
            }

            int currentMaxHeight = maxHeap.peek();
            // If the max height changed, we've found a key point
            if (currentMaxHeight != prevMaxHeight) {
                result.add(Arrays.asList(x, currentMaxHeight));
                prevMaxHeight = currentMaxHeight;
            }
        }

        return result;
    }
}
