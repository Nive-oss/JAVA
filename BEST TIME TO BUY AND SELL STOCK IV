class Solution {
    public int maxProfit(int k, int[] prices) {
        int n = prices.length;
        if (n <= 1 || k <= 0) return 0;

        // Optimization: If k is very large, it's equivalent to 
        // making as many transactions as possible (infinite transactions).
        if (k >= n / 2) {
            int profit = 0;
            for (int i = 1; i < n; i++) {
                if (prices[i] > prices[i - 1]) {
                    profit += prices[i] - prices[i - 1];
                }
            }
            return profit;
        }

        // buy[i] = lowest cost to buy for the i-th transaction
        // sell[i] = max profit after selling for the i-th transaction
        int[] buy = new int[k + 1];
        int[] sell = new int[k + 1];

        // Initialize buy prices to infinity
        java.util.Arrays.fill(buy, Integer.MAX_VALUE);

        for (int price : prices) {
            for (int i = 1; i <= k; i++) {
                // Minimized cost: price - profit from previous transaction
                buy[i] = Math.min(buy[i], price - sell[i - 1]);
                // Maximized profit: price - cost of current transaction
                sell[i] = Math.max(sell[i], price - buy[i]);
            }
        }

        return sell[k];
    }
}
