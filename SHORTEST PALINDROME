class Solution {
    public String shortestPalindrome(String s) {
        if (s == null || s.length() <= 1) return s;

        // Create a new string: original + "#" + reversed
        String rev = new StringBuilder(s).reverse().toString();
        String combined = s + "#" + rev;

        // Build the KMP LPS (Longest Prefix Suffix) array
        int[] lps = new int[combined.length()];
        for (int i = 1; i < combined.length(); i++) {
            int j = lps[i - 1];
            while (j > 0 && combined.charAt(i) != combined.charAt(j)) {
                j = lps[j - 1];
            }
            if (combined.charAt(i) == combined.charAt(j)) {
                j++;
            }
            lps[i] = j;
        }

        // The last value in the LPS array tells us the length of the 
        // longest prefix of 's' that is also a suffix of 'rev'.
        // This is exactly the longest palindromic prefix of 's'.
        int longestPalindromePrefixLen = lps[combined.length() - 1];
        
        // Take the part of 's' that isn't part of the prefix palindrome,
        // reverse it, and add it to the front.
        String suffixToAdd = s.substring(longestPalindromePrefixLen);
        String prefix = new StringBuilder(suffixToAdd).reverse().toString();
        
        return prefix + s;
    }
}
